{% comment %}
  quietto-bundle.liquid
  Sección #7 del template de homepage Quietto.
  Bundle picker: Quietto Único + Pack Convivencia.
  CTA principal → Pack Convivencia (destacado, terracota).
  ATC via Shopify Ajax Cart API (/cart/add.js) + redirect a /checkout.
  Sin preventa. Sin countdown. Precios directos.
  Conectar cada bloque a un producto real en Shopify Admin antes de lanzar.
{% endcomment %}

{{ 'quietto-custom.css' | asset_url | stylesheet_tag }}

<style>
  /* Subtítulo de cada pack */
  .q-bundle-card__subtitle {
    font-size: var(--q-text-sm);
    color: var(--q-charcoal-soft);
    line-height: 1.5;
    margin: 0;
  }

  /* Imagen del pack */
  .q-bundle-card__image {
    width: 100%;
    border-radius: var(--q-radius-md);
    overflow: hidden;
    background-color: var(--q-cream-dark);
    aspect-ratio: 4 / 3;
  }

  .q-bundle-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Nota pequeña bajo el botón CTA */
  .q-bundle-card__note {
    font-size: var(--q-text-xs);
    color: var(--q-charcoal-soft);
    text-align: center;
    font-style: italic;
    margin-top: var(--q-space-2);
    line-height: 1.5;
  }

  /* Trust badges bajo los packs */
  .q-bundle__trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--q-space-4) var(--q-space-8);
    margin-top: var(--q-space-8);
    padding-top: var(--q-space-6);
    border-top: 1px solid var(--q-border);
  }

  /* Estado loading del botón */
  .q-bundle-card__cta .q-btn[disabled] {
    opacity: 0.65;
    cursor: wait;
  }

  /* Separador visual entre packs en mobile */
  @media (max-width: 749px) {
    .q-bundle-card--featured {
      order: -1;
    }
  }
</style>

<section
  class="quietto-section q-section q-section--cream q-bundle"
  id="quietto-bundle"
  {{ section.shopify_attributes }}
>
  <div class="q-container">

    {%- comment -%} ENCABEZADO {%- endcomment -%}
    <div class="q-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="q-label">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="q-heading q-heading--section">
        {{ section.settings.headline | default: 'Elegí tu pack y empezá hoy.' }}
      </h2>

      {%- if section.settings.subhead != blank -%}
        <p class="q-subhead" style="max-width: 560px; margin: 0 auto;">
          {{ section.settings.subhead }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} CARDS DE PACK {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="q-bundle-picker">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pack' -%}

            {%- assign product_ref = block.settings.product -%}
            {%- assign variant_id = '' -%}
            {%- if product_ref != blank -%}
              {%- assign variant_id = product_ref.variants.first.id -%}
            {%- endif -%}

            <div
              class="q-bundle-card{% if block.settings.featured %} q-bundle-card--featured{% endif %}"
              {{ block.shopify_attributes }}
            >

              {%- comment -%} BADGE SUPERIOR {%- endcomment -%}
              {%- if block.settings.badge != blank -%}
                <div class="q-bundle-card__badge">
                  <span class="q-badge q-badge--popular">{{ block.settings.badge }}</span>
                </div>
              {%- endif -%}

              {%- comment -%} IMAGEN {%- endcomment -%}
              <div class="q-bundle-card__image">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 450, 600',
                      sizes: '(min-width: 750px) 30vw, 90vw',
                      alt: block.settings.name | default: 'Pack Quietto'
                  }}
                {%- elsif product_ref != blank and product_ref.featured_image != blank -%}
                  {{
                    product_ref.featured_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 450, 600',
                      sizes: '(min-width: 750px) 30vw, 90vw',
                      alt: product_ref.title
                  }}
                {%- else -%}
                  {%- comment -%} PLACEHOLDER: quietto-pack-{{ forloop.index }}.jpg — foto producto sobre fondo crema {%- endcomment -%}
                  <div class="q-img-placeholder" style="height: 100%; border-radius: 0; border: none;">
                    📦 quietto-pack-{{ forloop.index }}.jpg
                  </div>
                {%- endif -%}
              </div>

              {%- comment -%} NOMBRE Y SUBTÍTULO {%- endcomment -%}
              <div style="display: flex; flex-direction: column; gap: var(--q-space-1);">
                <h3 class="q-bundle-card__title">
                  {{ block.settings.name | default: 'Pack Quietto' }}
                </h3>
                {%- if block.settings.subtitle != blank -%}
                  <p class="q-bundle-card__subtitle">{{ block.settings.subtitle }}</p>
                {%- endif -%}
              </div>

              {%- comment -%} PRECIO {%- endcomment -%}
              <div class="q-bundle-card__price">
                <span class="q-bundle-card__price-main">
                  {{ block.settings.price_display | default: '' }}
                </span>
                {%- if block.settings.price_original != blank -%}
                  <span class="q-bundle-card__price-original">{{ block.settings.price_original }}</span>
                {%- endif -%}
                {%- if block.settings.price_savings != blank -%}
                  <span class="q-bundle-card__price-savings">{{ block.settings.price_savings }}</span>
                {%- endif -%}
              </div>

              {%- comment -%} INCLUSIONES {%- endcomment -%}
              {%- assign has_items = false -%}
              {%- for i in (1..6) -%}
                {%- assign item_key = 'item_' | append: i -%}
                {%- if block.settings[item_key] != blank -%}
                  {%- assign has_items = true -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if has_items -%}
                <ul class="q-bundle-card__includes" role="list">
                  {%- for i in (1..6) -%}
                    {%- assign item_key = 'item_' | append: i -%}
                    {%- if block.settings[item_key] != blank -%}
                      <li>{{ block.settings[item_key] }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- comment -%} CTA — AGREGAR AL CARRITO {%- endcomment -%}
              <div class="q-bundle-card__cta">
                {%- if variant_id != blank -%}
                  <form action="/cart/add" method="post" data-bundle-form novalidate>
                    <input type="hidden" name="id" value="{{ variant_id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button
                      type="submit"
                      class="q-btn q-btn--lg {% if block.settings.featured %}q-btn--primary{% else %}q-btn--ghost{% endif %}"
                      style="width: 100%;"
                      data-bundle-btn
                      data-original-text="{{ block.settings.cta_text | default: 'Llevarme este pack' | escape }}"
                    >
                      {{ block.settings.cta_text | default: 'Llevarme este pack' }}
                    </button>
                  </form>
                {%- else -%}
                  {%- comment -%} Sin producto conectado: botón placeholder — conectar en Shopify Admin {%- endcomment -%}
                  <button
                    type="button"
                    class="q-btn q-btn--lg {% if block.settings.featured %}q-btn--primary{% else %}q-btn--ghost{% endif %}"
                    style="width: 100%; opacity: 0.55; cursor: not-allowed;"
                    disabled
                    aria-disabled="true"
                  >
                    {{ block.settings.cta_text | default: 'Conectar producto →' }}
                  </button>
                {%- endif -%}

                {%- if block.settings.note != blank -%}
                  <p class="q-bundle-card__note">{{ block.settings.note }}</p>
                {%- endif -%}
              </div>

            </div>

          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} TRUST BADGES {%- endcomment -%}
    <div class="q-bundle__trust">
      {%- if section.settings.trust_1 != blank -%}
        <div class="q-trust-item">
          {%- if section.settings.trust_1_icon != blank -%}
            <span class="q-trust-item__icon" aria-hidden="true">{{ section.settings.trust_1_icon }}</span>
          {%- endif -%}
          <span>{{ section.settings.trust_1 }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.trust_2 != blank -%}
        <div class="q-trust-item">
          {%- if section.settings.trust_2_icon != blank -%}
            <span class="q-trust-item__icon" aria-hidden="true">{{ section.settings.trust_2_icon }}</span>
          {%- endif -%}
          <span>{{ section.settings.trust_2 }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.trust_3 != blank -%}
        <div class="q-trust-item">
          {%- if section.settings.trust_3_icon != blank -%}
            <span class="q-trust-item__icon" aria-hidden="true">{{ section.settings.trust_3_icon }}</span>
          {%- endif -%}
          <span>{{ section.settings.trust_3 }}</span>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

{%- comment -%}
  ATC via Ajax: POST a /cart/add.js → redirect a /checkout.
  Fallback nativo: si el fetch falla, el formulario hace POST normal a /cart/add.
{%- endcomment -%}
<script>
(function () {
  document.querySelectorAll('[data-bundle-form]').forEach(function (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn = form.querySelector('[data-bundle-btn]');
      var variantId = parseInt(form.querySelector('[name="id"]').value, 10);
      if (!variantId) return;

      btn.disabled = true;
      btn.textContent = 'Agregando…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
        .then(function (r) {
          if (!r.ok) throw new Error('cart_error');
          return r.json();
        })
        .then(function () {
          window.location.href = '/checkout';
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = btn.dataset.originalText;
        });
    });
  });
})();
</script>

