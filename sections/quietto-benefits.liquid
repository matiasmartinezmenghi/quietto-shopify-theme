{% comment %}
  quietto-benefits.liquid
  Sección #5 del template de homepage Quietto.
  Beneficios principales — refuerza confianza antes del bundle picker.
  Copy extraído del QUIETTO_MASTER_BRIEF.md sección 11.
  Estrategia: venta directa. Sin preventa. Sin claims absolutos.
  Íconos SVG de línea fina — sin emojis (brief sección 13).
{% endcomment %}

{{ 'quietto-custom.css' | asset_url | stylesheet_tag }}

<style>
  .q-benefit-item__title {
    font-family: var(--q-font-body);
    font-size: var(--q-text-base);
    font-weight: 600;
    color: var(--q-charcoal);
    line-height: 1.3;
    margin: 0;
  }

  .q-benefit-item__desc {
    font-size: var(--q-text-sm);
    color: var(--q-charcoal-soft);
    line-height: 1.55;
    margin: 0;
    font-weight: 400;
  }

  /* Beneficio destacado */
  .q-benefit-item--featured {
    border-color: var(--q-terracotta);
    border-width: 2px;
    position: relative;
  }

  .q-benefit-item--featured .q-benefit-item__title {
    color: var(--q-terracotta);
  }

  /* Ícono contenedor */
  .q-benefit-item__icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: var(--q-radius-md);
    background-color: var(--q-cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--q-sage);
    flex-shrink: 0;
  }

  .q-benefit-item--featured .q-benefit-item__icon-wrap {
    background-color: rgba(201, 125, 93, 0.10);
    color: var(--q-terracotta);
  }
</style>

{%- comment -%}
  Íconos SVG de línea fina reutilizados via case/when.
  Stroke-based, viewBox 24x24, stroke-width 1.5.
  Agregar nuevas opciones al select del schema si se expande el set.
{%- endcomment -%}

{%- capture icon_shield -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M12 2L4 5.5V10c0 5.25 3.6 9.7 8 11 4.4-1.3 8-5.75 8-11V5.5L12 2z"/>
  <path d="M9 12l2 2 4-4"/>
</svg>
{%- endcapture -%}

{%- capture icon_wave -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M9 9v6M12 6v12M6 11v2M15 7v10M18 9v6"/>
</svg>
{%- endcapture -%}

{%- capture icon_home -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M3 9.5L12 3l9 6.5V21a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
  <path d="M9 22V12h6v10"/>
</svg>
{%- endcapture -%}

{%- capture icon_book -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
  <line x1="9" y1="7" x2="15" y2="7"/>
  <line x1="9" y1="11" x2="13" y2="11"/>
</svg>
{%- endcapture -%}

{%- capture icon_hand -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M18 8h1a4 4 0 010 8h-1"/>
  <path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
  <line x1="6" y1="1" x2="6" y2="4"/>
  <line x1="10" y1="1" x2="10" y2="4"/>
  <line x1="14" y1="1" x2="14" y2="4"/>
</svg>
{%- endcapture -%}

{%- capture icon_calendar -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <rect x="3" y="4" width="18" height="18" rx="2"/>
  <line x1="16" y1="2" x2="16" y2="6"/>
  <line x1="8" y1="2" x2="8" y2="6"/>
  <line x1="3" y1="10" x2="21" y2="10"/>
  <path d="M9 16l2 2 4-4"/>
</svg>
{%- endcapture -%}

{%- capture icon_check -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <circle cx="12" cy="12" r="10"/>
  <path d="M9 12l2 2 4-4"/>
</svg>
{%- endcapture -%}

{%- capture icon_star -%}
<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
</svg>
{%- endcapture -%}

<section
  class="quietto-section q-section q-section--cream q-benefits"
  id="quietto-benefits"
  {{ section.shopify_attributes }}
>
  <div class="q-container">

    {%- comment -%} ENCABEZADO {%- endcomment -%}
    <div class="q-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="q-label">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="q-heading q-heading--section">
        {{ section.settings.headline | default: 'Lo que hace diferente a Quietto' }}
      </h2>

      {%- if section.settings.subhead != blank -%}
        <p class="q-subhead" style="max-width: 580px; margin: 0 auto;">
          {{ section.settings.subhead }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} GRID DE BENEFICIOS {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="q-benefits__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}

            {%- comment -%} Resolver ícono según key {%- endcomment -%}
            {%- assign icon_key = block.settings.icon_key -%}
            {%- case icon_key -%}
              {%- when 'shield'   -%}{%- assign icon_svg = icon_shield -%}
              {%- when 'wave'     -%}{%- assign icon_svg = icon_wave -%}
              {%- when 'home'     -%}{%- assign icon_svg = icon_home -%}
              {%- when 'book'     -%}{%- assign icon_svg = icon_book -%}
              {%- when 'hand'     -%}{%- assign icon_svg = icon_hand -%}
              {%- when 'calendar' -%}{%- assign icon_svg = icon_calendar -%}
              {%- when 'check'    -%}{%- assign icon_svg = icon_check -%}
              {%- when 'star'     -%}{%- assign icon_svg = icon_star -%}
              {%- else            -%}{%- assign icon_svg = icon_check -%}
            {%- endcase -%}

            <div
              class="q-benefit-item{% if block.settings.featured %} q-benefit-item--featured{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} ÍCONO {%- endcomment -%}
              <div class="q-benefit-item__icon-wrap q-benefit-item__icon">
                {{ icon_svg }}
              </div>

              {%- comment -%} TEXTOS {%- endcomment -%}
              <div style="display: flex; flex-direction: column; gap: var(--q-space-1);">
                {%- if block.settings.title != blank -%}
                  <p class="q-benefit-item__title">{{ block.settings.title }}</p>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <p class="q-benefit-item__desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>

          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Quietto — Beneficios",
  "tag": "section",
  "class": "quietto-benefits-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (texto sobre el título)",
      "placeholder": "Ej: Por qué Quietto"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Título de la sección",
      "default": "Lo que hace diferente a Quietto"
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subtítulo",
      "default": "Una herramienta simple para ayudarte a corregir hábitos sin recurrir a gritos, golpes ni descargas."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon_key",
          "label": "Ícono",
          "options": [
            { "value": "shield",   "label": "Escudo (seguridad / garantía)" },
            { "value": "wave",     "label": "Ondas (sonido / ultrasonido)" },
            { "value": "home",     "label": "Casa (interior / exterior)" },
            { "value": "book",     "label": "Libro (método / guía)" },
            { "value": "hand",     "label": "Mano (portátil / uso)" },
            { "value": "calendar", "label": "Calendario (días / plazo)" },
            { "value": "check",    "label": "Check círculo (confirmación)" },
            { "value": "star",     "label": "Estrella (destacado)" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título del beneficio",
          "info": "Corto y directo. Máximo 6 palabras."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "info": "1-2 líneas. Sin claims absolutos. Sin mencionar preventa."
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Destacar este beneficio",
          "default": false,
          "info": "Aplica borde terracota y título en color acento. Usar máximo 1 por sección."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quietto — Beneficios",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon_key": "shield",
            "title": "Sin shock, sin descarga, sin collar.",
            "description": "Quietto no se coloca en el perro ni usa contacto físico.",
            "featured": false
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_key": "wave",
            "title": "Inaudible para humanos.",
            "description": "La señal está pensada para llamar la atención del perro sin alterar tu casa.",
            "featured": false
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_key": "home",
            "title": "Para casa y paseos.",
            "description": "Podés usarlo frente a ladridos, timbre, visitas o reactividad en la calle.",
            "featured": false
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_key": "book",
            "title": "Método incluido.",
            "description": "La guía de 7 días te muestra cómo usarlo con constancia y refuerzo positivo.",
            "featured": true
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_key": "hand",
            "title": "Portátil y simple.",
            "description": "Lo llevás en la mano, mochila o cerca de la puerta para tenerlo cuando lo necesitás.",
            "featured": false
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_key": "calendar",
            "title": "30 días para probarlo.",
            "description": "Si no es para vos, tenés garantía de devolución.",
            "featured": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
