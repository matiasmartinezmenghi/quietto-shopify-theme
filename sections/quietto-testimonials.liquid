{% comment %}
  quietto-testimonials.liquid
  Sección #9 del template de homepage Quietto.
  Social proof honesta: dos modos intercambiables desde el editor.
    • trust_signals: 6 razones de confianza — no requiere clientes reales.
    • testimonials: grilla de reseñas reales — activar solo cuando existan.
  IMPORTANTE: no inventar nombres, fotos ni reseñas. Estado vacío honesto.
  Sin preventa, sin importación, sin resultados garantizados.
{% endcomment %}

{{ 'quietto-custom.css' | asset_url | stylesheet_tag }}

<style>
  /* ── Grid de testimonios reales ─────────────────────────────────────── */
  .q-testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--q-space-4);
  }

  @media (min-width: 750px) {
    .q-testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--q-space-5);
    }
  }

  /* ── Estado vacío (sin testimonios cargados) ────────────────────────── */
  .q-testimonials__empty {
    text-align: center;
    padding: var(--q-space-12) var(--q-space-6);
    background-color: var(--q-white);
    border-radius: var(--q-radius-lg);
    border: 1.5px dashed var(--q-border);
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--q-space-3);
  }

  .q-testimonials__empty-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .q-testimonials__empty-title {
    font-family: var(--q-font-heading);
    font-size: var(--q-text-lg);
    color: var(--q-charcoal);
    margin: 0;
    font-weight: 600;
  }

  .q-testimonials__empty-text {
    font-size: var(--q-text-sm);
    color: var(--q-charcoal-soft);
    line-height: 1.65;
    margin: 0;
    max-width: 400px;
    font-style: italic;
  }

  /* ── Card individual de testimonio ──────────────────────────────────── */
  .q-testimonial {
    display: flex;
    flex-direction: column;
    gap: var(--q-space-4);
  }

  .q-testimonial__stars {
    display: flex;
    gap: 2px;
    color: var(--q-terracotta);
    font-size: 1rem;
    line-height: 1;
    letter-spacing: 1px;
  }

  .q-testimonial__quote {
    font-size: var(--q-text-sm);
    color: var(--q-charcoal);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .q-testimonial__quote::before { content: '\201C'; }
  .q-testimonial__quote::after  { content: '\201D'; }

  .q-testimonial__author {
    display: flex;
    align-items: center;
    gap: var(--q-space-3);
    margin-top: auto;
  }

  .q-testimonial__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: var(--q-cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .q-testimonial__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .q-testimonial__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .q-testimonial__name {
    font-size: var(--q-text-sm);
    font-weight: 600;
    color: var(--q-charcoal);
    line-height: 1.3;
  }

  .q-testimonial__city {
    font-size: var(--q-text-xs);
    color: var(--q-charcoal-soft);
    line-height: 1.3;
  }

  .q-testimonial__verified {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--q-sage);
    background-color: rgba(157, 182, 164, 0.12);
    border-radius: var(--q-radius-full);
    padding: 2px 7px;
    margin-top: 3px;
    width: fit-content;
  }

  /* ── Grid de trust signals ──────────────────────────────────────────── */
  .q-testimonials__trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--q-space-3);
  }

  @media (min-width: 750px) {
    .q-testimonials__trust-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--q-space-5);
    }
  }

  /* Card individual de trust signal */
  .q-trust-signal {
    background-color: var(--q-white);
    border: 1.5px solid var(--q-border);
    border-radius: var(--q-radius-lg);
    padding: var(--q-space-5) var(--q-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--q-space-2);
  }

  .q-trust-signal__icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .q-trust-signal__title {
    font-size: var(--q-text-sm);
    font-weight: 600;
    color: var(--q-charcoal);
    line-height: 1.35;
    margin: 0;
  }

  .q-trust-signal__desc {
    font-size: var(--q-text-xs);
    color: var(--q-charcoal-soft);
    line-height: 1.55;
    margin: 0;
  }

  /* ── CTA al pie ─────────────────────────────────────────────────────── */
  .q-testimonials__footer {
    margin-top: var(--q-space-10);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--q-space-3);
  }

  .q-testimonials__note {
    font-size: var(--q-text-xs);
    color: var(--q-charcoal-soft);
    font-style: italic;
    max-width: 480px;
    line-height: 1.6;
  }
</style>

<section
  class="quietto-section q-section q-section--cream-dark q-testimonials"
  id="quietto-testimonials"
  {{ section.shopify_attributes }}
>
  <div class="q-container">

    {%- comment -%} ENCABEZADO {%- endcomment -%}
    <div class="q-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="q-label">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="q-heading q-heading--section">
        {{ section.settings.headline | default: 'Por qué elegir Quietto' }}
      </h2>

      {%- if section.settings.subhead != blank -%}
        <p class="q-subhead" style="max-width: 580px; margin: 0 auto;">
          {{ section.settings.subhead }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} MODO: trust_signals o testimonials {%- endcomment -%}
    {%- assign display_mode = section.settings.display_mode | default: 'trust_signals' -%}

    {%- if display_mode == 'trust_signals' -%}

      {%- comment -%} ── MODO TRUST SIGNALS ─────────────────────────────── {%- endcomment -%}
      {%- assign has_trust = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_item' -%}{%- assign has_trust = true -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_trust -%}
        <div class="q-testimonials__trust-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_item' -%}
              <div class="q-trust-signal" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="q-trust-signal__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <p class="q-trust-signal__title">{{ block.settings.title }}</p>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="q-trust-signal__desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    {%- else -%}

      {%- comment -%} ── MODO TESTIMONIOS REALES ────────────────────────── {%- endcomment -%}
      {%- assign has_testimonials = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}{%- assign has_testimonials = true -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_testimonials -%}

        <div class="q-testimonials__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial' -%}
              <div
                class="q-card q-card--testimonial q-testimonial"
                {{ block.shopify_attributes }}
              >

                {%- comment -%} Estrellas (solo si el usuario las activa) {%- endcomment -%}
                {%- if block.settings.show_stars -%}
                  {%- assign stars = block.settings.star_count | default: 5 -%}
                  <div class="q-testimonial__stars" aria-label="{{ stars }} de 5 estrellas">
                    {%- for i in (1..5) -%}
                      {%- if i <= stars -%}★{%- else -%}☆{%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- comment -%} Texto de la reseña {%- endcomment -%}
                {%- if block.settings.text != blank -%}
                  <p class="q-testimonial__quote">{{ block.settings.text }}</p>
                {%- endif -%}

                {%- comment -%} Autor {%- endcomment -%}
                <div class="q-testimonial__author">

                  {%- comment -%} Avatar {%- endcomment -%}
                  <div class="q-testimonial__avatar">
                    {%- if block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 80
                        | image_tag:
                          loading: 'lazy',
                          widths: '40, 80',
                          sizes: '40px',
                          alt: block.settings.name | default: 'Cliente'
                      }}
                    {%- else -%}
                      🐾
                    {%- endif -%}
                  </div>

                  {%- comment -%} Nombre, ciudad y badge {%- endcomment -%}
                  <div class="q-testimonial__meta">
                    {%- if block.settings.name != blank -%}
                      <span class="q-testimonial__name">{{ block.settings.name }}</span>
                    {%- endif -%}
                    {%- if block.settings.city != blank -%}
                      <span class="q-testimonial__city">{{ block.settings.city }}</span>
                    {%- endif -%}
                    {%- if block.settings.show_verified -%}
                      <span class="q-testimonial__verified">
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M20 6L9 17l-5-5"/>
                        </svg>
                        Verificado
                      </span>
                    {%- endif -%}
                  </div>

                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

      {%- else -%}

        {%- comment -%} ESTADO VACÍO — honesto y editable {%- endcomment -%}
        <div class="q-testimonials__empty">
          <span class="q-testimonials__empty-icon" aria-hidden="true">🐾</span>
          <p class="q-testimonials__empty-title">
            {{ section.settings.empty_title | default: 'Opiniones reales próximamente' }}
          </p>
          <p class="q-testimonials__empty-text">
            {{ section.settings.empty_text | default: 'Estamos preparando esta sección para mostrar experiencias reales de quienes prueben Quietto. No inventamos reseñas: preferimos mostrar resultados reales cuando estén disponibles.' }}
          </p>
        </div>

      {%- endif -%}

    {%- endif -%}

    {%- comment -%} PIE: CTA opcional + nota de honestidad {%- endcomment -%}
    <div class="q-testimonials__footer">
      {%- if section.settings.cta_text != blank -%}
        <a
          href="{{ section.settings.cta_url | default: '#quietto-bundle' }}"
          class="q-btn q-btn--secondary"
        >
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}
      {%- if section.settings.footer_note != blank -%}
        <p class="q-testimonials__note">{{ section.settings.footer_note }}</p>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Quietto — Social proof",
  "tag": "section",
  "class": "quietto-testimonials-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Modo de visualización"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Modo",
      "options": [
        {
          "value": "trust_signals",
          "label": "Razones de confianza (sin testimonios reales)"
        },
        {
          "value": "testimonials",
          "label": "Testimonios reales (activar cuando haya clientes)"
        }
      ],
      "default": "trust_signals",
      "info": "Usar 'Razones de confianza' hasta tener reseñas reales verificadas. Cambiar a 'Testimonios reales' solo cuando agregues bloques con reseñas reales."
    },
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "placeholder": "Ej: Por qué elegir Quietto"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Título",
      "default": "Por qué elegir Quietto"
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subtítulo",
      "default": "Una herramienta honesta, con método incluido y garantía real."
    },
    {
      "type": "header",
      "content": "Estado vacío (solo modo testimonios)"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Título del estado vacío",
      "default": "Opiniones reales próximamente",
      "info": "Se muestra en modo testimonios cuando no hay bloques cargados."
    },
    {
      "type": "textarea",
      "id": "empty_text",
      "label": "Texto del estado vacío",
      "default": "Estamos preparando esta sección para mostrar experiencias reales de quienes prueben Quietto. No inventamos reseñas: preferimos mostrar resultados reales cuando estén disponibles."
    },
    {
      "type": "header",
      "content": "CTA y pie"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del CTA (opcional)",
      "placeholder": "Ej: Ver el Pack Convivencia"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link del CTA",
      "info": "Dejar vacío para apuntar a #quietto-bundle."
    },
    {
      "type": "textarea",
      "id": "footer_note",
      "label": "Nota al pie",
      "default": "Cuando tengamos experiencias reales de compradores, las vamos a publicar acá con autorización.",
      "info": "Texto en itálica pequeña. Refuerza honestidad. Dejar vacío para ocultar."
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Razón de confianza",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono (emoji)",
          "placeholder": "Ej: 🛡️"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "info": "Corto y directo. Máximo 6 palabras."
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripción (opcional)",
          "info": "1 línea de contexto extra."
        }
      ]
    },
    {
      "type": "testimonial",
      "name": "Testimonio real",
      "settings": [
        {
          "type": "header",
          "content": "⚠️ Usar solo con reseñas reales de clientes verificados"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto del cliente (opcional)",
          "info": "Solo con autorización del cliente. Si no hay foto, se muestra ícono 🐾."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre (opcional)",
          "placeholder": "Ej: Martina R."
        },
        {
          "type": "text",
          "id": "city",
          "label": "Ciudad (opcional)",
          "placeholder": "Ej: Buenos Aires"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto de la reseña",
          "info": "Citar textualmente. No editar ni embellecer la reseña del cliente."
        },
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Mostrar estrellas",
          "default": false,
          "info": "Activar solo si el cliente dejó una calificación real."
        },
        {
          "type": "range",
          "id": "star_count",
          "label": "Cantidad de estrellas",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "info": "Solo visible si 'Mostrar estrellas' está activado."
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Mostrar badge 'Verificado'",
          "default": false,
          "info": "Activar solo cuando sea un cliente real que compró en Quietto. No usar por defecto."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quietto — Social proof",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "🛡️",
            "title": "30 días para probarlo",
            "description": "Si no funciona en tu perro, te devolvemos el 100%."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "💬",
            "title": "Atención por WhatsApp",
            "description": "Una persona real te responde, no un bot."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "📖",
            "title": "Guía de 7 días incluida",
            "description": "El método que te enseña a usar Quietto bien desde el primer día."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "🛒",
            "title": "Compra directa",
            "description": "Sin intermediarios. Atención directa del equipo Quietto."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "↩️",
            "title": "Garantía de devolución",
            "description": "Sin formularios largos. Sin justificar. Hablamos por WhatsApp."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "🐾",
            "title": "Sin collar ni descarga",
            "description": "Quietto no se coloca en el perro. Sin contacto, sin shock."
          }
        }
      ]
    }
  ]
}
{% endschema %}
