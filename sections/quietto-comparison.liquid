      "info": "Ej: Recomendado / Nuestra elección. Dejar vacío para ocultar."
    },
    {
      "type": "header",
      "content": "Pie de tabla"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Texto aclaratorio al pie",
