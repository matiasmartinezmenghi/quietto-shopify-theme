        {
          "type": "row",
          "settings": {
            "label": "Uso diario",
            "col1_type": "text", "col1_value": "Por sesiones con agenda",
            "col2_type": "text", "col2_value": "Constante en el perro",
            "col3_type": "text", "col3_value": "A demanda, cuando lo necesitás"
          }
