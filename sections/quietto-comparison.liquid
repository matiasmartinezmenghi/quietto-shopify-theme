      "info": "Aparece con borde verde salvia. Refuerza honestidad de marca."
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Fila comparativa",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta de la fila",
          "placeholder": "Ej: Costo inicial"
        },
        {
          "type": "header",
          "content": "Columna 1 — Adiestrador"
        },
        {
          "type": "select",
          "id": "col1_type",
          "label": "Tipo de celda",
          "options": [
            { "value": "text",  "label": "Texto" },
            { "value": "check", "label": "Check (✓)" },
            { "value": "cross", "label": "Dash (—)" }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "id": "col1_value",
          "label": "Valor",
          "placeholder": "Ej: $200.000+"
        },
        {
          "type": "header",
          "content": "Columna 2 — Collar"
        },
        {
          "type": "select",
          "id": "col2_type",
          "label": "Tipo de celda",
          "options": [
            { "value": "text",  "label": "Texto" },
            { "value": "check", "label": "Check (✓)" },
            { "value": "cross", "label": "Dash (—)" }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "id": "col2_value",
          "label": "Valor",
          "placeholder": "Ej: Se coloca en el perro"
        },
        {
          "type": "header",
          "content": "Columna 3 — Quietto"
        },
        {
          "type": "select",
          "id": "col3_type",
          "label": "Tipo de celda",
          "options": [
            { "value": "text",  "label": "Texto" },
            { "value": "check", "label": "Check (✓)" },
            { "value": "cross", "label": "Dash (—)" }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "id": "col3_value",
          "label": "Valor",
          "placeholder": "Ej: Sin collar"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quietto — Comparativa",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "label": "Costo inicial",
            "col1_type": "text", "col1_value": "$150.000 – $300.000+",
            "col2_type": "text", "col2_value": "$20.000 – $80.000",
            "col3_type": "text", "col3_value": "$35.000 – $59.900"
          }
        },
        {
          "type": "row",
          "settings": {
            "label": "Requiere colocar algo en el perro",
            "col1_type": "cross", "col1_value": "",
            "col2_type": "text",  "col2_value": "Sí — collar",
            "col3_type": "check", "col3_value": "No"
          }
