<section
  class="quietto-section q-section q-guarantees"
  id="quietto-guarantees"
  {{ section.shopify_attributes }}
>
  <div class="q-container">

    {%- comment -%} ENCABEZADO {%- endcomment -%}
    <div class="q-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="q-label">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="q-heading q-heading--section">
        {{ section.settings.headline | default: 'Comprá tranquilo. Estamos para ayudarte.' }}
      </h2>

      {%- if section.settings.subhead != blank -%}
        <p class="q-subhead" style="max-width: 580px; margin: 0 auto;">
          {{ section.settings.subhead }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} GRID DE GARANTÍAS {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="q-guarantees__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'guarantee' -%}

            {%- comment -%} Resolver ícono {%- endcomment -%}
            {%- assign icon_key = block.settings.icon_key -%}
            {%- case icon_key -%}
              {%- when 'shield'    -%}{%- assign icon_svg = icon_shield -%}
              {%- when 'calendar'  -%}{%- assign icon_svg = icon_calendar -%}
              {%- when 'truck'     -%}{%- assign icon_svg = icon_truck -%}
              {%- when 'message'   -%}{%- assign icon_svg = icon_message -%}
              {%- when 'zap_off'   -%}{%- assign icon_svg = icon_zap_off -%}
              {%- when 'hand'      -%}{%- assign icon_svg = icon_hand -%}
              {%- when 'check'     -%}{%- assign icon_svg = icon_check -%}
              {%- when 'lock'      -%}{%- assign icon_svg = icon_lock -%}
              {%- else             -%}{%- assign icon_svg = icon_check -%}
            {%- endcase -%}

            <div
              class="q-guarantee-item"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} ÍCONO {%- endcomment -%}
              <div class="q-guarantee-item__icon">
                {{ icon_svg }}
              </div>

              {%- comment -%} TEXTOS {%- endcomment -%}
              <div style="display: flex; flex-direction: column; gap: var(--q-space-2); align-items: center;">
                {%- if block.settings.title != blank -%}
                  <p class="q-guarantee-item__title">{{ block.settings.title }}</p>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <p class="q-guarantee-item__desc">{{ block.settings.description }}</p>
                {%- endif -%}

                {%- comment -%} Link WhatsApp opcional {%- endcomment -%}
                {%- if block.settings.whatsapp_url != blank -%}
                  <a
                    href="{{ block.settings.whatsapp_url }}"
                    class="q-guarantee-item__link"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="{{ block.settings.whatsapp_label | default: 'Escribinos por WhatsApp' }}"
                  >
                    {{ block.settings.whatsapp_label | default: 'Escribinos →' }}
                  </a>
                {%- endif -%}
              </div>
            </div>

          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} TEXTO LEGAL AL PIE {%- endcomment -%}
    {%- if section.settings.legal_text != blank -%}
      <p class="q-guarantees__legal">{{ section.settings.legal_text }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Quietto — Garantías",
  "tag": "section",
  "class": "quietto-guarantees-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "placeholder": "Ej: Comprá con confianza"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Título",
      "default": "Comprá tranquilo. Estamos para ayudarte."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subtítulo",
      "default": "Quietto está pensado para que puedas probarlo sin presión, con atención humana y garantía clara."
    },
    {
      "type": "header",
      "content": "Pie legal"
    },
    {
      "type": "textarea",
      "id": "legal_text",
      "label": "Texto aclaratorio al pie (opcional)",
      "default": "La garantía no reemplaza las condiciones de uso responsable. Quietto es una herramienta de apoyo para entrenamiento, no un producto veterinario.",
      "info": "Texto pequeño en itálica bajo el grid. Refuerza honestidad y evita expectativas incorrectas."
    }
  ],
  "blocks": [
    {
      "type": "guarantee",
      "name": "Garantía / confianza",
      "settings": [
        {
          "type": "select",
          "id": "icon_key",
          "label": "Ícono",
          "options": [
            { "value": "shield",   "label": "Escudo (garantía / seguridad)" },
            { "value": "calendar", "label": "Calendario (días / plazo)" },
            { "value": "truck",    "label": "Camión (envío / entrega)" },
            { "value": "message",  "label": "Mensaje (WhatsApp / contacto)" },
            { "value": "zap_off",  "label": "Sin descarga (seguridad del producto)" },
            { "value": "hand",     "label": "Mano (sin collar / uso)" },
            { "value": "check",    "label": "Check círculo (confirmación)" },
            { "value": "lock",     "label": "Candado (seguridad / privacidad)" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título del bloque",
          "info": "Corto y directo. Máximo 5 palabras."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "info": "1-2 líneas. Sin claims absolutos."
        },
        {
          "type": "header",
          "content": "Link de WhatsApp (opcional)"
        },
        {
          "type": "url",
          "id": "whatsapp_url",
          "label": "URL de WhatsApp",
          "info": "Ej: https://wa.me/5491XXXXXXXXX — Dejar vacío para ocultar."
        },
        {
          "type": "text",
          "id": "whatsapp_label",
          "label": "Texto del link",
          "default": "Escribinos →",
          "info": "Solo visible si se completa la URL de WhatsApp."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quietto — Garantías",
      "blocks": [
        {
          "type": "guarantee",
          "settings": {
            "icon_key": "calendar",
            "title": "30 días para probarlo",
            "description": "Si no es para vos, podés pedir la devolución dentro de los 30 días.",
            "whatsapp_url": "",
            "whatsapp_label": "Escribinos →"
          }
        },
        {
          "type": "guarantee",
          "settings": {
            "icon_key": "truck",
            "title": "Envío según tu ubicación",
            "description": "Te mostramos las opciones disponibles al momento de la compra.",
            "whatsapp_url": "",
            "whatsapp_label": "Escribinos →"
          }
        },
        {
          "type": "guarantee",
          "settings": {
            "icon_key": "message",
            "title": "Atención por WhatsApp",
            "description": "Te ayudamos con dudas de uso, compra o garantía.",
            "whatsapp_url": "",
            "whatsapp_label": "Escribinos →"
          }
        },
        {
          "type": "guarantee",
          "settings": {
            "icon_key": "zap_off",
            "title": "Sin collar ni descarga",
            "description": "Una herramienta de apoyo para entrenar sin contacto físico.",
            "whatsapp_url": "",
            "whatsapp_label": "Escribinos →"
          }
        }
      ]
    }
  ]
}
{% endschema %}
